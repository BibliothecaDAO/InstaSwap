# build output
insta-sdk/dist

# Logs
insta-sdk/logs
insta-sdk/*.log
insta-sdk/npm-debug.log*
insta-sdk/yarn-debug.log*
insta-sdk/yarn-error.log*
insta-sdk/lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
insta-sdk/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
insta-sdk/pids
insta-sdk/*.pid
insta-sdk/*.seed
insta-sdk/*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
insta-sdk/lib-cov

# Coverage directory used by tools like istanbul
insta-sdk/coverage
insta-sdk/*.lcov

# Compiled binary addons (https://nodejs.org/api/addons.html)
insta-sdk/build/Release

# Dependency directories
insta-sdk/node_modules/
insta-sdk/jspm_packages/

# TypeScript cache
insta-sdk/*.tsbuildinfo

# Optional npm cache directory
insta-sdk/.npm

# Optional eslint cache
insta-sdk/.eslintcache

# Optional REPL history
insta-sdk/.node_repl_history

# Output of 'npm pack'
insta-sdk/*.tgz

# Yarn Integrity file
insta-sdk/.yarn-integrity

# dotenv environment variables file
.env
.env.test

# parcel-bundler cache (https://parceljs.org/)
insta-sdk/.cache
insta-sdk/.parcel-cache

# yarn v2
insta-sdk/.yarn/cache
insta-sdk/.yarn/unplugged
insta-sdk/.yarn/build-state.yml
insta-sdk/.yarn/install-state.gz
insta-sdk/.pnp.*